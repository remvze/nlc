{
  "name": "nlc",
  "version": "0.2.0",
  "description": "💾 A lightweight, AI-powered terminal assistant for natural language commands.",
  "main": "dist/bin/nlc.mjs",
  "bin": {
    "nlc": "dist/bin/nlc.mjs"
  },
  "files": [
    "dist/bin/nlc.mjs"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "commit": "git-cz",
    "release": "standard-version --no-verify",
    "release:major": "pnpm run release --release-as major",
    "release:minor": "pnpm run release --release-as minor",
    "release:patch": "pnpm run release --release-as patch",
    "build": "tsup-node",
    "dev": "tsup-node --watch",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ai",
    "terminal",
    "llm",
    "nlp"
  ],
  "author": "Maze Heart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remvze/nlc.git"
  },
  "bugs": {
    "url": "https://github.com/remvze/nlc/issues"
  },
  "homepage": "https://github.com/remvze/nlc#readme",
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@tsconfig/node20": "^20.1.6",
    "@types/node": "^24.0.10",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "standard-version": "9.5.0",
    "tsup": "8.5.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.53",
    "@inquirer/prompts": "7.6.0",
    "@vscode/ripgrep": "1.17.1",
    "ai": "6.0.168",
    "boxen": "8.0.1",
    "chalk": "5.4.1",
    "cli-highlight": "2.1.11",
    "commander": "14.0.0",
    "conf": "14.0.0",
    "dotenv": "17.4.2",
    "exec-sh": "0.4.0",
    "execa": "9.6.1",
    "log-symbols": "7.0.1",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0",
    "zod": "3.25.76"
  }
}
